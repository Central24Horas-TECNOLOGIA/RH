                    Aprovar
                  </button>
                  <button
                    type="button"
                    class="btn btn-outline-danger"
                    onClick=${() => aplicarAcao('Eliminado')}
                  >
                    Eliminar
                  </button>
                  <button
                    type="button"
                    class="btn btn-outline-secondary"
                    onClick=${() => aplicarAcao('Banco de talentos')}
                  >
                    Banco de talentos
                  </button>
                </div>
                <button
                  type="button"
                  class="btn btn-primary"
                  onClick=${() => setDetalhe(null)}
                >
                  Fechar
                </button>
              </footer>
            `
          : null}
      </${ModalPadrao}>
    </${PainelRh}>
  `;
}



