# Ambiente
RH_APP_ENV=development
RH_LOG_LEVEL=INFO

# Banco SQL Server
RH_SQL_SERVER=PAULO_TI\SQLEXPRESS
RH_SQL_DATABASE=RH_Provas
RH_SQL_DRIVER=ODBC Driver 17 for SQL Server

# Autenticacao local
RH_AUTH_USER=rh.local
RH_AUTH_PASSWORD=troque-esta-senha
RH_AUTH_TOKEN_SECRET=troque-este-segredo
RH_AUTH_TOKEN_TTL_MINUTES=480

# CORS
RH_CORS_ALLOW_ORIGINS=http://127.0.0.1:5500,http://localhost:5500,http://127.0.0.1:3000,http://localhost:3000,null
RH_CORS_ALLOW_ORIGIN_REGEX=https?://(localhost|127\\.0\\.0\\.1)(:\\d+)?
